class Solution {
    public int search(int[] nums, int target) {
        int st=0;
        int end=nums.length-1;
        while(st<=end){
            int mid=st+(end-st)/2;
            if(nums[mid]==target){
                return mid;
            }
            if(nums[st]<=nums[mid]){ //check if left half is sorted
                if(target>=nums[st] && target<nums[mid]){ //target is found in left sorted array
                    end=mid-1;
                }else{
                    st=mid+1;
                }
            }else{ //right half is sorted
            if(target>nums[mid] && target<=nums[end]){ //target is found i  right sorted array
                st=mid+1;
            }else{
                end=mid-1;
            }
            }

        }
        return -1;
    }
}
