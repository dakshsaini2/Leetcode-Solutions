from functools import cache

class Solution:
    def isMatch(self, s: str, p: str) -> bool:
        @cache
        def dfs(i: int, j: int) -> bool:
            # Base cases
            if j == len(p):
                return i == len(s)
            
            # First character match check
            first_match = i < len(s) and (p[j] == s[i] or p[j] == '.')
            
            # If next char in pattern is '*'
            if j + 1 < len(p) and p[j + 1] == '*':
                # Option 1: Use '*' zero times
                # Option 2: Use '*' one or more times (if first_match)
                return dfs(i, j + 2) or (first_match and dfs(i + 1, j))
            
            # Normal character or '.'
            return first_match and dfs(i + 1, j + 1)
        
        return dfs(0, 0)
